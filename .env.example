# Copy this file to .env and fill in your values.
# Never commit .env - it's gitignored for a reason.

# Get a free Gemini API key at https://aistudio.google.com/apikey
# No credit card required.
VITE_GEMINI_API_KEY=your_key_here

# Optional: for Act 3 Track A (fallback chain demo)
# Create additional keys from different Google accounts if you want to
# demonstrate the fallback chain firing on a real 429. Leave blank otherwise.
VITE_GEMINI_KEY_1=
VITE_GEMINI_KEY_2=
VITE_GEMINI_KEY_3=